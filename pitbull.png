<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>For My Love 💕</title>
<style>

body{
    margin:0;
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(
        135deg,
        #ffd6ea,
        #ffe8f3
    );
    font-family:sans-serif;
    overflow:hidden;
}

.card{
    width:90%;
    max-width:420px;
    background:white;
    border-radius:25px;
    padding:25px;
    text-align:center;
    box-shadow:0 10px 30px rgba(0,0,0,0.15);
}

.dog{
    width:180px;
    border-radius:20px;
    margin-bottom:10px;
}

h1{
    color:#ff5c9f;
    font-size:26px;
}

.date-option{
    display:block;
    margin:12px 0;
    font-size:18px;
}

.yes{
    background:#ff77b7;
    color:white;
    border:none;
    padding:12px 24px;
    border-radius:25px;
    font-size:18px;
    cursor:pointer;
    margin-right:10px;
}

.no{
    background:#c98cff;
    color:white;
    border:none;
    padding:12px 24px;
    border-radius:25px;
    font-size:18px;
    cursor:pointer;
    position:absolute;
}

.heart{
    position:fixed;
    font-size:30px;
    pointer-events:none;
    animation:floatUp 3s linear forwards;
}

@keyframes floatUp{
    from{
        transform:translateY(0);
        opacity:1;
    }
    to{
        transform:translateY(-100vh);
        opacity:0;
    }
}

.message{
    margin-top:20px;
    color:#ff5c9f;
    font-weight:bold;
    font-size:18px;
}

</style>
</head>
<body>
<div class="card">
<img src="pitbull.png" class="dog">
<h1>🌸 Will you go on a date with me? 🌸</h1>
<p>Choose a day 💕</p>
<label class="date-option">
<input type="radio" name="date" value="7月8日">
🌸 7月8日
</label>
<label class="date-option">
<input type="radio" name="date" value="8月8日">
💕 8月8日
</label>
<label class="date-option">
<input type="radio" name="date" value="8月26日">
🎂 8月26日
</label>
<br>
<button class="yes" onclick="sayYes()">
YES 💖
</button>
<button class="no" id="noBtn">
NO
</button>
<div id="result" class="message"></div>
</div>
<script>

function createHeart(){

const heart=document.createElement("div");

heart.className="heart";

heart.innerHTML="💖";

heart.style.left=
Math.random()*100+"vw";

heart.style.bottom="0px";

document.body.appendChild(heart);

setTimeout(()=>{
heart.remove();
},3000);

}

function sayYes(){

const selected=
document.querySelector(
'input[name="date"]:checked'
);

if(!selected){

alert(
"日付を選んでね🥺💕"
);

return;

}

for(let i=0;i<40;i++){

setTimeout(
createHeart,
i*100
);

}

document.getElementById("result").innerHTML=

"💖 選んでくれてありがとう 💖<br><br>" +

"選んでくれた日： " +

selected.value +

"<br><br>一緒に素敵な思い出を作ろうね🥰🌸<br><br>大好きだよ❤️";

}

const btn=
document.getElementById("noBtn");

btn.addEventListener(
"mouseover",
()=>{

btn.style.left=
Math.random()*
(window.innerWidth-120)
+"px";

btn.style.top=
Math.random()*
(window.innerHeight-60)
+"px";

}
);

</script>
</body>
</html>
